# .env.example — Copia este archivo como .env y rellena tus valores
# NUNCA hagas commit del archivo .env real

# ── GitHub API Token (OBLIGATORIO para autenticación) ──────────────────────
# Genera uno en: https://github.com/settings/tokens
# Permisos mínimos requeridos: public_repo (lectura), no se necesita escritura
GITHUB_TOKEN=ghp_YOUR_TOKEN_HERE

# ── Límites de escaneo ──────────────────────────────────────────────────────
MAX_REPOS=10
MAX_FILES_PER_REPO=100
MAX_FILE_SIZE=500000

# ── Concurrencia ──────────────────────────────────────────────────────────────
MAX_WORKERS=5

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PAUSE=2.0
RATE_LIMIT_MIN_REM=10

# ── Logging ───────────────────────────────────────────────────────────────────
# Niveles: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
